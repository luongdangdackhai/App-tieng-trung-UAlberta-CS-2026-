<Window x:Class="App_test.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:App_test"
        mc:Ignorable="d"
        Loaded="LoadData"
        Title="MainWindow" Height="450" Width="800">
    <ListView x:Name="lvHSK">
        <ListView.View>
            <GridView>
                <GridViewColumn Header="12345" Width="150" DisplayMemberBinding="{Binding Path=simplified}"/>
                
                <GridViewColumn Header="frequency" Width="150"
                                DisplayMemberBinding="{Binding Path=frequency}"/>
                               
            </GridView>
        </ListView.View>
    </ListView>

</Window>
